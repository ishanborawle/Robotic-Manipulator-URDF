    <origin xyz="0.006536167375728557 -0.003893892459322812 0.025264938655354285" rpy="0 0 0"/>
    <mass value="4.250514906118769"/>
    <inertia ixx="0.00579" iyy="0.00579" izz="0.004025" ixy="-0.0" iyz="-0.0" ixz="-0.0"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
